{
  "version": 2,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/jobs/send-due-capsules",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/jobs/send-daily-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}
